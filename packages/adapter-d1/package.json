{
  "name": "@baynet/adapter-d1",
  "version": "0.1.0",
  "description": "Cloudflare D1 database adapter for BayNet SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@baynet/sdk": "*",
    "drizzle-orm": "^0.39.0"
  },
  "devDependencies": {
    "@baynet/tsconfig": "*",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.35.0"
  },
  "license": "MIT"
}
